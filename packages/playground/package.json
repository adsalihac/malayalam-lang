{
  "name": "@malayalamlang/playground",
  "version": "0.1.0",
  "description": "Interactive playground for the Malayalam programming language",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "malayalam",
    "programming-language",
    "playground",
    "interactive",
    "education"
  ],
  "author": "MalayalamLang Contributors",
  "license": "MIT",
  "homepage": "https://github.com/adsalihac/malayalam-lang#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adsalihac/malayalam-lang.git",
    "directory": "packages/playground"
  },
  "bugs": {
    "url": "https://github.com/adsalihac/malayalam-lang/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
