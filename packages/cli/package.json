{
  "name": "@malayalamlang/cli",
  "version": "0.1.0",
  "description": "Malayalam language CLI and REPL — write code in Malayalam!",
  "type": "module",
  "bin": {
    "malayalam": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "malayalam",
    "programming-language",
    "cli",
    "repl",
    "compiler",
    "manglish"
  ],
  "author": "MalayalamLang Contributors",
  "license": "MIT",
  "homepage": "https://github.com/adsalihac/malayalam-lang#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adsalihac/malayalam-lang.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/adsalihac/malayalam-lang/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/readline-sync": "^1.4.4",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "@malayalamlang/core": "workspace:*",
    "@malayalamlang/runtime": "workspace:*",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "readline-sync": "^1.4.10"
  }
}
