{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Malayalam",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.malayalam",
          "match": "//.*$",
          "comment": "Line comments"
        },
        {
          "name": "comment.block.malayalam",
          "begin": "/\\*",
          "end": "\\*/",
          "comment": "Block comments"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.malayalam",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.malayalam",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.malayalam",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.malayalam",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.malayalam",
          "match": "\\b([0-9]+\\.[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.integer.malayalam",
          "match": "\\b([0-9]+)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.malayalam",
          "match": "\\b(എങ്കിൽ|അല്ലെങ്കിൽ|എന്ത്|എല്ലാം|ശ്രമിക്കുക|പിടിക്കുക|മടങ്ങി|തകർക്കുക|തുടരുക)\\b"
        },
        {
          "name": "keyword.other.malayalam",
          "match": "\\b(ഫങ്ക്ഷൻ|കോൺസ്ടാന്റ്|വേരിയബിൾ|ക്ലാസ്)\\b"
        },
        {
          "name": "constant.language.malayalam",
          "match": "\\b(സത്യം|കള്ളം|ശൂന്യം)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.malayalam",
          "match": "\\b(കാണിക്കുക|ചേർക്കുക|നീളം|സ്ലൈസ്|സോർട്ട്|ഫിൽട്ടർ|മാപ്പ്)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.malayalam",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.malayalam",
          "match": "(\\+|-|\\*|/|%|=|==|!=|<|>|<=|>=|&&|\\|\\||!)"
        }
      ]
    }
  },
  "scopeName": "source.malayalam"
}
