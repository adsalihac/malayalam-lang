{
  "name": "malayalam-language",
  "displayName": "Malayalam Language",
  "version": "0.1.0",
  "description": "Write code in Malayalam! Syntax highlighting, IntelliSense, and language support for the Malayalam programming language.",
  "type": "module",
  "publisher": "malayalamlang",
  "galleryBanner": {
    "color": "#003d7a",
    "theme": "dark"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "activationEvents": [
    "onLanguage:malayalam"
  ],
  "contributes": {
    "languages": [
      {
        "id": "malayalam",
        "aliases": [
          "Malayalam",
          "malayalam"
        ],
        "extensions": [
          ".ml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "malayalam",
        "scopeName": "source.malayalam",
        "path": "./syntaxes/malayalam.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "package": "vsce package --no-dependencies",
    "publish": "node publish.mjs",
    "publish:auto": "node publish.mjs --publish"
  },
  "keywords": [
    "malayalam",
    "programming-language",
    "vscode",
    "extension",
    "language-support"
  ],
  "author": "MalayalamLang Contributors",
  "license": "MIT",
  "homepage": "https://github.com/adsalihac/malayalam-lang#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adsalihac/malayalam-lang.git"
  },
  "bugs": {
    "url": "https://github.com/adsalihac/malayalam-lang/issues"
  },
  "files": [
    "dist",
    "syntaxes",
    "language-configuration.json",
    "icon.png",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  }
}
